<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Teaghans MMA Inventory</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <div class="page-header">
    <main class="page-logo">
      <a href="/">
        <img
        src="/images/lightning-logo.png"
        alt="Thunder Bear Logo"
        class="small-logo"
      />
      </a>
    </main>
    <h1 class="section-title">Categories</h1>
  </div>
  <ul class="item-list">
    <% categories.forEach(cat => { %>
      <li>
        <a class="list-item" href="/items?category=<%= cat.id %>"><%= cat.name %></a>
        <a href="/categories/<%= cat.id %>/delete" class="deleteCatBtn">✕</a>
      </li>
    <% }) %>
  </ul>
  <div class="transition-buttons">
    <a href="/" class="nav-btn">Home</a>
    <a href="/categories/search" class="nav-btn">Search</a>
    <a href="/categories/deleteAll" class="nav-btn">Delete All Categories</a>
  </div>
</body>
</html>