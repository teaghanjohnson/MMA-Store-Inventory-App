<!DOCTYPE html>
<html>
  <meta charset="UTF-8" />
  <title>Teaghan's MMA Inventory</title>
  <body>
    <h1>Create Category</h1>
    <form method="POST" action="/category/new">
      <label for="name">Name</label>
      <input type="text" id="catName" name="name" />
      <label for="description">Description</label>
      <input type="text" id="catDescription" name="description" />
      <button type="submit" id="submitBtn">Submit</button>
    </form>
  </body>
</html>
